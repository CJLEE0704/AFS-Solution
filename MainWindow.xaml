<Window x:Class="PipeBendingDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="CI Pipe Bending Control Suite"
        Icon="wwwroot/favicon.ico"
        Height="900" Width="1600"
        MinHeight="720" MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="#09111A"
        WindowState="Maximized">

    <Window.Resources>
        <!-- 타이틀바 다크 테마 (Windows 11) -->
        <ResourceDictionary/>
    </Window.Resources>

    <Grid>
        <!-- WebView2 가 전체 화면을 채움 -->
        <wv2:WebView2 x:Name="webView"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Visibility="Collapsed"/>

        <!-- 로딩 스플래시 (WebView2 초기화 전 표시) -->
        <Grid x:Name="splashGrid" Background="#09111A">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Image Source="wwwroot/logo_ci_white_main.png"
                       Width="260"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>
                <TextBlock Text="PIPE BENDING CONTROL"
                           Foreground="#83BCD8"
                           FontSize="22"
                           FontWeight="Bold"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="CI Co., Ltd."
                           Foreground="#8EA1B5"
                           FontSize="14"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>
                <ProgressBar x:Name="loadingBar"
                             Width="300" Height="4"
                             IsIndeterminate="True"
                             Background="#203245"
                             Foreground="#83BCD8"/>
                <TextBlock x:Name="loadingText"
                           Text="Industrial control suite initializing..."
                           Foreground="#8EA1B5"
                           FontSize="12"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
